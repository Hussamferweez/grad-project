              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"johndoe\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe.{{$timestamp}}@example.com\",\n  \"phoneNumber\": \"+201234567890\",\n  \"password\": \"Password1\",\n  \"dateOfBirth\": \"1990-05-15\",\n  \"address\": \"123 Main St, Cairo\"\n}"
            },
            "url": "{{baseUrl}}/api/Auth/register"
          }
        }
      ]
    },
    {
      "name": "02 - Services",
      "description": "Requires any authenticated user. GET returns raw array (no ApiResponse wrapper).",
      "item": [
        {
          "name": "Get All Services",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const services = pm.response.json();",
                  "if (Array.isArray(services) && services.length > 0) {",
                  "    pm.collectionVariables.set('serviceId', services[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/Services"
          }
        },
        {
          "name": "Create Service",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Filling\",\n  \"approximateDurationMinutes\": 45\n}"
            },
            "url": "{{baseUrl}}/api/Services"
          }
        }
      ]
    },

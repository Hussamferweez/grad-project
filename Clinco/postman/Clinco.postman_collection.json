    {
      "name": "04 - Schedules",
      "item": [
        {
          "name": "Create Schedule (Doctor/Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.data?.id) {",
                  "        pm.collectionVariables.set('scheduleId', json.data.id);",
                  "    }",
                  "    pm.test('Schedule created', () => pm.expect(json.succeeded).to.be.true);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dentistId\": {{dentistId}},\n  \"dayOfWeek\": \"Monday\",\n  \"startTime\": \"09:00\",\n  \"endTime\": \"17:00\",\n  \"date\": \"{{appointmentDate}}\",\n  \"isAvailable\": true\n}"
            },
            "url": "{{baseUrl}}/api/Schedules"
          }
        },
        {
          "name": "Get Schedules By Dentist",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/Schedules/dentist/{{dentistId}}?from={{appointmentDate}}&to={{appointmentDate}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "Schedules", "dentist", "{{dentistId}}"],
              "query": [
                { "key": "from", "value": "{{appointmentDate}}" },
                { "key": "to", "value": "{{appointmentDate}}" }
              ]
            }
          }
        },
        {
          "name": "Get Available Schedules",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/Schedules/available?from={{appointmentDate}}&to={{appointmentDate}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "Schedules", "available"],
              "query": [
                { "key": "from", "value": "{{appointmentDate}}" },
                { "key": "to", "value": "{{appointmentDate}}" }
              ]
            }
          }
        },
        {
          "name": "Update Schedule Availability (Admin)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isAvailable\": true\n}"
            },
            "url": "{{baseUrl}}/api/Schedules/{{scheduleId}}/availability"
          }
        }
      ]
    },
    {
      "name": "05 - Appointments",
      "description": "Book requires Receptionist or Admin token. Patient self-book endpoint is disabled in the API.",
      "item": [
        {
          "name": "Book Appointment (Receptionist/Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.data?.id) {",
                  "        pm.collectionVariables.set('appointmentId', json.data.id);",
                  "    }",
                  "    pm.test('Appointment booked', () => pm.expect(json.succeeded).to.be.true);",
                  "    pm.test('Status is Booked', () => pm.expect(json.data.status).to.eql('Booked'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"dentistId\": {{dentistId}},\n  \"appointmentDate\": \"{{appointmentDate}}\",\n  \"appointmentTime\": \"{{appointmentTime}}\",\n  \"serviceId\": {{serviceId}},\n  \"createdBy\": {{receptionistId}},\n  \"scheduleId\": null\n}"
            },
            "url": "{{baseUrl}}/api/Appointments/manage/book"
          }
        },
        {
          "name": "Get Appointment By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/Appointments/{{appointmentId}}"
          }
        },
        {
          "name": "Get My Appointments (Patient)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/Appointments/my"
          }
        },
        {
          "name": "Get Appointments By Patient (ClinicStaff)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/Appointments/patient/{{patientId}}"
          }
        },
        {
          "name": "Get Appointments By Date (ClinicStaff)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/Appointments/date/{{appointmentDate}}"
          }
        },
        {
          "name": "Get Appointments By Dentist (ClinicStaff)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/Appointments/dentist/{{dentistId}}?date={{appointmentDate}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "Appointments", "dentist", "{{dentistId}}"],
              "query": [{ "key": "date", "value": "{{appointmentDate}}" }]
            }
          }
        },
        {
          "name": "Confirm Appointment (Receptionist/Admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"confirm\",\n  \"newDate\": null,\n  \"newTime\": null,\n  \"serviceName\": null\n}"
            },
            "url": "{{baseUrl}}/api/Appointments/{{appointmentId}}"
          }
        },
        {
          "name": "Reschedule Appointment (Receptionist/Admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"reschedule\",\n  \"newDate\": \"{{appointmentDate}}\",\n  \"newTime\": \"14:00\",\n  \"serviceName\": null\n}"
            },
            "url": "{{baseUrl}}/api/Appointments/{{appointmentId}}"
          }
        },
        {
          "name": "Complete Appointment (Receptionist/Admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"complete\",\n  \"newDate\": null,\n  \"newTime\": null,\n  \"serviceName\": null\n}"
            },
            "url": "{{baseUrl}}/api/Appointments/{{appointmentId}}"
          }
        },
        {
          "name": "Cancel Appointment",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/Appointments/{{appointmentId}}/cancel"
          }
        }
      ]
    },
    {
      "name": "06 - Delays",
      "description": "Requires Doctor or Admin token.",
      "item": [
        {
          "name": "Mark Delay on Appointment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.test('Delay marked', () => pm.expect(json.succeeded).to.be.true);",
                  "    pm.test('Status is Delayed', () => pm.expect(json.data.status).to.eql('Delayed'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appointmentId\": {{appointmentId}},\n  \"delayDurationMinutes\": 30,\n  \"reason\": \"Emergency procedure running late\"\n}"
            },
            "url": "{{baseUrl}}/api/Delays"
          }
        }
      ]
    },
    {
      "name": "07 - Notifications",
      "item": [
        {
          "name": "Notify Patients of Delay (Receptionist/Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 202) {",
                  "    const json = pm.response.json();",
                  "    pm.test('Notification accepted', () => pm.expect(json.succeeded).to.be.true);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],

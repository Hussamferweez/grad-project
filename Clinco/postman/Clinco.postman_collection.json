              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.data?.length > 0) {",
                  "        pm.collectionVariables.set('dentistId', json.data[0].id);",
                  "    }",

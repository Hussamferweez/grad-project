{
  "info": {
    "_postman_id": "clinco-api-collection-v1",
    "name": "Clinco API",
    "description": "Dental clinic management REST API (.NET 9).\n\n**Setup:** Import `Clinco-Local.postman_environment.json`, start the API (`dotnet run --project Clinco.Api`), then run requests in order.\n\n**Demo password for all seeded accounts:** `Password1`\n\n**Seeded IDs (fresh database):**\n- Admin: 1 | Doctor: 2 | Receptionist: 3 | Patient: 4\n- Services: 1–4 (Cleaning, Root Canal, Whitening, General Checkup)\n- Roles: 1=Admin, 2=Doctor, 3=Receptionist, 4=Patient",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5098" },
    { "key": "accessToken", "value": "" },
    { "key": "userId", "value": "3" },
    { "key": "adminId", "value": "1" },
    { "key": "dentistId", "value": "2" },
    { "key": "receptionistId", "value": "3" },
    { "key": "patientId", "value": "4" },
    { "key": "serviceId", "value": "1" },
    { "key": "appointmentId", "value": "1" },
    { "key": "scheduleId", "value": "1" },
    { "key": "appointmentDate", "value": "2026-06-25" },
    { "key": "appointmentTime", "value": "10:00" }
  ],
  "item": [
    {
      "name": "01 - Auth",
      "description": "No authentication required. Login requests auto-save `accessToken` and `userId` to collection variables.",
      "item": [
        {
          "name": "Login - Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.data?.accessToken) {",
                  "        pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "        pm.collectionVariables.set('userId', json.data.userId);",
                  "    }",
                  "    pm.test('Login succeeded', () => pm.expect(json.succeeded).to.be.true);",
                  "    pm.test('Role is Admin', () => pm.expect(json.data.role).to.eql('Admin'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"admin@clinico.com\",\n  \"password\": \"Password1\"\n}"
            },
            "url": "{{baseUrl}}/api/Auth/login"
          }
        },
        {
          "name": "Login - Doctor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",

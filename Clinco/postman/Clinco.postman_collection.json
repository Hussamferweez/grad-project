                  "    if (json.data?.accessToken) {",
                  "        pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "        pm.collectionVariables.set('userId', json.data.userId);",
                  "    }",
                  "    pm.test('Login succeeded', () => pm.expect(json.succeeded).to.be.true);",
                  "    pm.test('Role is Doctor', () => pm.expect(json.data.role).to.eql('Doctor'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"doctor@clinico.com\",\n  \"password\": \"Password1\"\n}"
            },

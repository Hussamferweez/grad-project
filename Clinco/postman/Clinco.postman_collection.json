          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Mona\",\n  \"lastName\": \"Ali\",\n  \"phoneNumber\": \"+201000000002\",\n  \"address\": \"Cairo, Egypt\",\n  \"emergencyContact\": \"+201099999999\"\n}"
            },
            "url": "{{baseUrl}}/api/Users/profile"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Password1\",\n  \"newPassword\": \"NewPassword1\"\n}"
            },
            "url": "{{baseUrl}}/api/Users/change-password"
          }
        },
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/Users"
          }
